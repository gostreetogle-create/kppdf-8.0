# KPPDF 8.0 — конфиг деплоя (скопируй в config.env и заполни)
# copy deploy\synology\config.env.example deploy\synology\config.env

PLATFORM=ubuntu

# Публичный IP Synology/роутера (SSH с WAN не работает — используй LAN)
DEPLOY_HOST=192.168.1.103
DEPLOY_USER=tiit
# DEPLOY_PASSWORD=

# Код (перезаписывается при деплое)
REMOTE_DIR=/opt/kppdf-8.0
# Данные Mongo + uploads + backups (НЕ трогаются)
KPPDF_DATA_DIR=/var/lib/kppdf80

JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_HEX
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_64_HEX

CORS_ORIGIN=https://sport-set.ru

# Sentry (error tracking) — оставить пустым чтобы отключить
SENTRY_DSN=

# Первый деплой
SEED=true
