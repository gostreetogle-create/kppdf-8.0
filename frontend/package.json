    "culori": "^4.0.2",
    "jest": "^29",
    "jest-environment-jsdom": "^29",
    "jest-preset-angular": "^14",
    "postcss": "^8.4.49",
    "puppeteer": "^23",
    "ts-jest": "^29",
    "tsx": "^4",
    "typescript": "~5.9.2"
