{
  "name": "kppdf-frontend",
  "version": "1.0.0-pi",
  "description": "Paper & Ink — editorial Swiss-minimalism Angular SPA UI kit showcase",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
