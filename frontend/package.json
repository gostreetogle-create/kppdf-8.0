    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "clsx": "^2.1.1",
    "highlight.js": "^11",
    "lucide-angular": "^0.460.0",
    "marked": "^18.0.6",
