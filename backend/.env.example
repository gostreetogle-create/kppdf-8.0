NODE_ENV=development
PORT=3000

# MongoDB (Replica Set required for transactions)
MONGO_URI=mongodb://localhost:27017/kppdf?replicaSet=rs0
MONGO_DB=kppdf
MONGO_REPLICA_SET=rs0

# CORS (comma-separated whitelist)
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# Logging
LOG_LEVEL=debug

# JWT
JWT_SECRET=change-me-to-a-long-random-string-min-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another-long-random-string-different-from-access
JWT_REFRESH_EXPIRES_IN=7d

# Default admin (created on first boot if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin-change-me-immediately-in-production

# Throttler (rate limiting)
# THROTTLE_TTL_SHORT=1000  # window in ms
# THROTTLE_LIMIT_SHORT=10
# THROTTLE_TTL_LONG=60000
# THROTTLE_LIMIT_LONG=100
# DISABLE_THROTTLE=1
