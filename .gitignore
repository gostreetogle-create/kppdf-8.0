# Dependencies
node_modules/
.pnpm-store/
.pnp
.pnp.js
# Root npm lockfile. backend + frontend use pnpm; root has no deps of its
# own (`pnpm-lock.yaml` lives in each subproject). If `npm install` ever
# runs at repo root, this empty lockfile regenerates — ignored so it
# cannot pollute commits.
package-lock.json

# Build artifacts
dist/
build/
out/
*.tsbuildinfo
.nest/

# Environment & secrets
.env
.env.local
.env.*.local
.env.example.local

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
desktop.ini
nul

# Editor
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp
*.swo
*~
.cursor/

# Test coverage
coverage/
.nyc_output/

# Temporary / cache
.tmp/
_tmp/
.cache/
.turbo/
.parcel-cache/
.eslintcache
.stylelintcache

# OrchestratorKit runtime state (locks are transient)
.mimocode/locks/

# Local helper binaries
mimo.exe

# codebase-memory MCP server (TZ-deferred vendor-bundle)
# Track metadata + runner script, exclude the large binary + runtime caches.
# See vendor/codebase-memory-mcp/README.md for rationale + install steps on fresh clone.
vendor/codebase-memory-mcp/bin/*.exe
vendor/codebase-memory-mcp/index/
vendor/codebase-memory-mcp/cache/
vendor/codebase-memory-mcp/.codebase-memory/

# Runtime PID tracker from start.mjs (kept on disk; not tracked in git)
.start.pids.json

# Uploaded files (runtime)
backend/uploads/*
!backend/uploads/.gitkeep
tmp/
