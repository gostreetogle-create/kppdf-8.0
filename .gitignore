# codebase-memory MCP server (TZ-deferred vendor-bundle)
# Track metadata + runner script, exclude the large binary + runtime caches.
# See vendor/codebase-memory-mcp/README.md for rationale + install steps on fresh clone.
vendor/codebase-memory-mcp/bin/*.exe
vendor/codebase-memory-mcp/index/
vendor/codebase-memory-mcp/cache/
vendor/codebase-memory-mcp/.codebase-memory/

# Runtime PID tracker from start.mjs (kept on disk; not tracked in git)
.start.pids.json

# Uploaded files (runtime)
backend/uploads/*
!backend/uploads/.gitkeep
tmp/
tmp/tz9*-{commit,arch}-*.txt

# Design reference snapshot — brutalist UI source bundle from
# `ui/stitch_professional_desktop_crm_refinement/` (4.3MB, 16 brutalist
# editorial UI kits). Served as inspiration ONLY for TZ-93 + TZ-95 + TZ-96
# (pi-tech-label, pi-dashed-panel, hairline-first). Adoption matrix is
# documented in `tasks/_archive/2026-07/TZ-{93,93.1,95,96}.md.done` —
# live tree doesn't need a copy. Regenerable from original source URL
# referenced in TZ-93 spec §1 finding if a future TZ needs the source.
ui/stitch_professional_desktop_crm_refinement/

# === DOCUMENTATION (explicitly tracked) ===
# All docs/ content is VITAL and MUST be version-controlled.
# The SECTION BELOW ensures nothing in docs/ is ever accidentally caught
# by broader ignore patterns (e.g., tmp/, stitch_*, or future additions).
# If you add a new docs/ subdirectory, it is automatically protected.
!docs/**
