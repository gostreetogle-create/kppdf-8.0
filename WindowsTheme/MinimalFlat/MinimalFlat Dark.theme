Size=NormalSize

[boot]
SCRNSAVE.EXE=%SystemRoot%\System32\scrnsave.scr

[Metrics]
IconMetrics=84,11
MetricType=0
NonClientMetrics=13,13,13,13,13,13,13

[Desktop]
Wallpaper=%SystemRoot%\Web\Wallpaper\Windows\img0.jpg
TileWallpaper=0
WallpaperStyle=10
Pattern=

[Sounds]
; Minimal Flat Sound Scheme - using Windows defaults
