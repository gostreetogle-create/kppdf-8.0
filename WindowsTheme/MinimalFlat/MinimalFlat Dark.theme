[Theme]
DisplayName=Minimal Flat Dark
ThemeId={A7B8C9D0-1234-5678-9ABC-DEF012345678}

[MasterTheme]
DisplayName=Minimal Flat Dark

[VisualStyles]
Path=%ResourceDir%\Themes\MinimalFlat Dark\MinimalFlat Dark.theme
