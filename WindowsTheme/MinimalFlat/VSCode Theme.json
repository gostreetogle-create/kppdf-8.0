        "badge.background": "#0D9488",
        "badge.foreground": "#FFFFFF",
        "progressBar.background": "#0D9488",
        "list.activeSelectionBackground": "#0D948830",
        "list.activeSelectionForeground": "#D4D4D4",
        "list.inactiveSelectionBackground": "#2D2D2D",
        "list.inactiveSelectionForeground": "#D4D4D4",
        "list.hoverBackground": "#2D2D2D",
        "list.highlightForeground": "#0D9488",
        "gitDecoration.modifiedResourceForeground": "#FBBF24",
        "gitDecoration.deletedResourceForeground": "#F87171",
        "gitDecoration.untrackedResourceForeground": "#0D9488",
        "gitDecoration.conflictingResourceForeground": "#A78BFA",
        "minimap.background": "#1E1E1E",
        "editorIndentGuide.background": "#404040",
        "editorIndentGuide.activeBackground": "#0D9488",
        "editorLineNumber.foreground": "#6B7280",
        "editorLineNumber.activeForeground": "#D4D4D4"
    },
    "tokenColors": [
        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#6B7280", "fontStyle": "italic" }
        },
        {
            "scope": ["string", "string.quoted"],
            "settings": { "foreground": "#5EEAD4" }
        },
        {
            "scope": ["constant.numeric"],
            "settings": { "foreground": "#FBBF24" }
        },
        {
            "scope": ["keyword", "storage", "storage.type"],
            "settings": { "foreground": "#A78BFA" }
        },
        {
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#60A5FA" }
        },
        {
            "scope": ["entity.name.type", "entity.other.inherited-class"],
            "settings": { "foreground": "#22D3EE" }
        },
        {
            "scope": ["variable", "variable.other"],
            "settings": { "foreground": "#D4D4D4" }
        },
        {
            "scope": ["variable.parameter"],
            "settings": { "foreground": "#FCA5A5" }
        },
        {
            "scope": ["keyword.control"],
            "settings": { "foreground": "#F87171" }
        },
        {
            "scope": ["entity.other.attribute-name"],
            "settings": { "foreground": "#FBBF24" }
        }
    ]
}
