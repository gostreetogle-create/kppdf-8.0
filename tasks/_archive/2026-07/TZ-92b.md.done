## 3. Что меняется

### 3.1 `frontend/src/app/app.routes.ts` (JSDoc only, no behavior change)

Add explicit JSDoc to the `/kit/*` route declaration:

```typescript
{
  // TZ-92b: /kit/* is intentionally PUBLIC (no canMatch guard).
  // This is the UI-Kit showcase — design tokens, component demos, theme editor,
  // code preview. No sensitive data; no backend mutations. Safe to expose to
  // browser-use and external reviewers. DO NOT add canMatch: [authGuard] here.
  // See tasks/TZ-92b.md for the reasoning + tests.
  path: 'kit',
  loadComponent: () =>
    import('./layout/kit-layout.component').then(
      (m) => m.KitLayoutComponent,
    ),
  children: [
    // ... existing children unchanged
  ],
},
```

**Behavior change:** NONE. Routes still public (no canMatch).
**Defensive value:** Future contributors won't accidentally gate /kit/*.

### 3.2 `frontend/src/app/core/auth.guard.ts` (add `publicGuard` no-op)

Add a third guard that explicitly signals "this route is intentionally public" (vs. just missing a guard, which could be an oversight):

```typescript
/**
 * Explicit "always allow" guard for public routes.
 *
 * Functionally equivalent to NOT having a guard, but makes the public
 * intent visible in route declarations (instead of implying it via absence).
 *
 * Use for: /kit/* and any future showcase / docs / landing routes.
 * DO NOT use for: /login (use publicOnlyGuard instead) or any route that
 * actually requires auth (use authGuard).
 *
 * TZ-92b rationale: future contributors might see a route without canMatch
 * and assume "oh, I forgot to add authGuard, let me add it". This guard
 * makes the intent explicit at the call site.
 */
export const publicGuard: CanMatchFn = () => true;
```

**Then in `app.routes.ts`:** add `canMatch: [publicGuard]` to the `/kit/*` route:

```typescript
{
  path: 'kit',
  canMatch: [publicGuard],                              // ← TZ-92b: explicit public
  loadComponent: () => import('./layout/kit-layout.component'),
  // ...
},
```

**Behavior change:** Still always allows (CanMatchFn returns true). The guard is a no-op, but its presence is a defensive signal.

**Tradeoff:** The no-op guard adds 1 line per route. For 9 children, that's 9 extra lines. But each one is a defensive comment via the guard name. Alternative: add JSDoc only, no guard. Both are valid; the spec recommends the no-op guard for explicitness.

### 3.3 `frontend/src/app/app.routes.spec.ts` (NEW — route accessibility test)

Add a new spec file that verifies all `/kit/*` routes are accessible without auth:

```typescript
import { TestBed } from '@angular/core/testing';
import { provideRouter } from '@angular/router';
import { Router } from '@angular/router';
import { routes } from './app.routes';

/**
 * TZ-92b: route accessibility contract.
 *
 * The /kit/* route subtree is intentionally PUBLIC (no authGuard).
 * These tests pin that contract so future contributors can't accidentally
 * add canMatch: [authGuard] and break browser-use visual verify.
 */
describe('app.routes (TZ-92b contract)', () => {
  let router: Router;

  beforeEach(() => {
    TestBed.configureTestingModule({
      providers: [provideRouter(routes)],
    });
    router = TestBed.inject(Router);
  });

  const publicKitPaths = [
    '/kit',
    '/kit/overview',
    '/kit/foundations',
    '/kit/basics',
    '/kit/forms',
    '/kit/overlays',
    '/kit/navigation',
    '/kit/playground/theme',
    '/kit/playground/code',
  ];

  it.each(publicKitPaths)(
    '%s should NOT have canMatch that blocks anonymous access',
    async (path) => {
      const config = router.config.find((r) => {
        // Match the /kit route and any of its children
        if (r.path === 'kit' && path === '/kit') return true;
        if (r.path === 'kit' && path.startsWith('/kit/')) {
          // /kit/* children — the parent /kit route decides canMatch
          return false; // handled by parent test
        }
        return false;
      });

      if (!config) {
        // Look for a child of /kit matching the path
        const kitRoute = router.config.find((r) => r.path === 'kit');
        const child = kitRoute?.children?.find((c) => {
          const childPath = c.path ? `/kit/${c.path}` : '/kit';
          return childPath === path;
        });
        if (!child) throw new Error(`No route found for ${path}`);
        expect(child.canMatch).toBeFalsy(); // Children don't need canMatch
        return;
      }

      // The /kit parent route has canMatch: [publicGuard] (always true)
      // or NO canMatch (also always allows).
      // Both are acceptable; just ensure no authGuard.
      const guards = (config.canMatch ?? []).map((g) => g.name ?? 'anonymous');
      expect(guards).not.toContain('authGuard');
    },
  );

  it('operational site (/*) still requires authGuard', () => {
    const operationalRoute = router.config.find((r) => r.path === '');
    expect(operationalRoute).toBeTruthy();
    const guards = (operationalRoute!.canMatch ?? []).map(
      (g) => g.name ?? 'anonymous',
    );
    expect(guards).toContain('authGuard');
  });

  it('/login uses publicOnlyGuard', () => {
    const loginRoute = router.config.find((r) => r.path === 'login');
    expect(loginRoute).toBeTruthy();
    const guards = (loginRoute!.canMatch ?? []).map(
      (g) => g.name ?? 'anonymous',
    );
    expect(guards).toContain('publicOnlyGuard');
  });
});
```

**Behavior change:** New test file. No production code change.

